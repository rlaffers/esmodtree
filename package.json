{
  "name": "esmodtree",
  "private": true,
  "description": "ES Module import tree visualizer",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "format": "pnpm exec prettier . --write",
    "format:check": "pnpm exec prettier . --check",
    "typecheck": "pnpm exec tsc -b",
    "typecheck:ci": "pnpm exec tsc -b --pretty false",
    "typecheck:packages": "pnpm -r run typecheck",
    "prepare": "husky",
    "check": "pnpm format:check && pnpm typecheck"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
