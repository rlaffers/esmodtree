{
  "name": "esmodtree",
  "private": true,
  "description": "ES Module import tree visualizer",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "format": "pnpm exec prettier . --write && pnpm -r run format",
    "format:check": "pnpm exec prettier . --check && pnpm -r run format:check",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "husky",
    "check": "pnpm format:check && pnpm typecheck",
    "release": "pnpm --filter @esmodtree/cli exec semantic-release",
    "release:local": "op run --env-file=.env.release -- pnpm --filter @esmodtree/cli exec semantic-release --no-ci"
  },
  "keywords": [],
  "author": "",
  "license": "GPLv3",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
